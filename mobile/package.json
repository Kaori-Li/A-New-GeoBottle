{
  "name": "mobile",
  "version": "1.0.0",
  "description": "GeoBottle React Native mobile client",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "npm run test:smoke && npm run test:unit && npm run test:e2e",
    "test:smoke": "node scripts/smoke-check.js",
    "test:unit": "jest --runInBand --testPathIgnorePatterns=\\.e2e\\.test\\.js$",
    "test:e2e": "jest --runInBand --testMatch \"**/__tests__/**/*.e2e.test.js\"",
    "test:e2e:maestro": "maestro test e2e/maestro/login-and-permission-flow.yaml"
  },
  "keywords": [
    "react-native",
    "geolocation",
    "geobottle"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.1",
    "axios": "^1.13.6",
    "react": "^18.3.1",
    "react-native": "^0.74.7",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-maps": "^1.27.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "babel-jest": "^29.7.0"
  }
}
