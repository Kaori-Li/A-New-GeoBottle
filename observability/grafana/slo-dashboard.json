{
  "title": "GeoBottle SLO Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Availability (30d)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "1 - (sum(rate(geobottle_http_requests_total{status_code=~\"5..\"}[30d])) / clamp_min(sum(rate(geobottle_http_requests_total[30d])), 1))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 Latency (ms)",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(geobottle_http_request_duration_ms_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Login Failure Ratio",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(geobottle_auth_login_failures_total[5m])) / clamp_min(sum(rate(geobottle_http_requests_total{route=\"/api/auth/login\"}[5m])), 1)",
          "refId": "A"
        }
      ]
    }
  ]
}
